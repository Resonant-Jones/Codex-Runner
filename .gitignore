# Python bytecode and caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artifacts
build/
dist/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
.envrc

# Editor and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs and local state
*.log
*.sqlite3
*.sqlite
*.db

# Codex Runner local runtime outputs (Pi Loop dry-run evidence)
# Generated by `codexrun loop` under <repo_root>/.pi/runs/<run_id>/.
# Receipts are evidence, not source. See
# docs/review/CODEX_RUNNER_GENERATED_ARTIFACT_HYGIENE.md
.pi/

# Guardian local generated session logs
# Written by `codexrun guardian validate-plan-pack --write-session-log`.
# Session logs are generated evidence, not source.
.guardian/sessions/

# Environment and secrets
.env
.env.*
*.key
*.pem
*.token

# Local auth/config payloads
auth.json
config.local.*
*.local.toml
*.local.yaml
*.local.yml
